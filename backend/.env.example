# Copy to .env and fill every line marked REQUIRED.

# --- REQUIRED (server will not start without these) ---
PORT=3000
MONGODB_URI=mongodb://localhost:27017/policypay
SOLANA_RPC_URL=https://api.devnet.solana.com
PROGRAM_ID=
COMPLIANCE_ISSUER_SECRET_KEY=
# Path to policypay.json (relative to backend cwd, or absolute). Repo includes backend/idl/policypay.json — regenerate after `anchor build` if the program changes.
IDL_PATH=./idl/policypay.json

# --- Optional API auth ---
# If set, all /api/* routes require header: x-api-key: <value> OR Authorization: Bearer <value>
# Generate:  openssl rand -hex 32
# Or Node:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Leave empty only for local dev without auth.
BACKEND_API_KEY=

USE_ONCHAIN_POLICY=false

# SIX MTLS + FX/risk inputs (required for orchestrated fx/risk derivation)
# SIX REST base (docs use https://api.six-group.com/web/v2)
SIX_API_BASE_URL=https://api.six-group.com/web/v2
# Header value used by SIX APIs: `api-version: <SIX_API_VERSION>`
SIX_API_VERSION=2025-06-01
#
# Base64-encoded PEM contents (preferred over file paths).
# Populate by base64-encoding your `signed-certificate.pem` and `private-key.pem` from the SIX hackathon materials.
SIX_MTLS_CERT_PEM_BASE64=
SIX_MTLS_KEY_PEM_BASE64=
# Certificate password for your P12 (kept for completeness; not required for the PEM-based MTLS client).
SIX_MTLS_P12_PASSWORD=

# IDs used for intradaySnapshot call: `scheme=VALOR_BC&ids=<SIX_FX_SNAPSHOT_IDS>`
SIX_FX_SNAPSHOT_IDS=

# Optional deterministic FX risk thresholds (on the internal 0..1 normalized scale)
SIX_FX_RISK_HIGH_THRESHOLD=
SIX_FX_RISK_MEDIUM_THRESHOLD=

# Partner HTTP (required for POST /api/payments/*/orchestrated)
PARTNER_HTTP_TIMEOUT_MS=15000
AMINA_API_URL=
AMINA_API_KEY=
SOLSTICE_API_URL=
SOLSTICE_API_KEY=
KEYROCK_API_URL=
KEYROCK_API_KEY=

ENABLE_FIREBLOCKS_GATE=false
FIREBLOCKS_SIM_URL=
FIREBLOCKS_SIM_API_KEY=

KYT_MAX_TX_PER_DAY=1000
KYT_MAX_VOLUME_PER_DAY=999999999999
KYT_API_URL=
KYT_API_KEY=
